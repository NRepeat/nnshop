# nnshop environment variables
# Copy to .env.local and fill in real values
# NEVER commit .env.local to git

# Public (client-accessible)
NEXT_PUBLIC_BASE_URL=https://your-domain.com
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_POSTHOG_KEY=phc_XXXX
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# PostHog Error Tracking (server-only, build-time sourcemap upload)
POSTHOG_PERSONAL_API_KEY=phx_XXXX
POSTHOG_PROJECT_ID=XXXX
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-10-19
NEXT_PUBLIC_NP_WIDGET_API_KEY=your_np_api_key

# Auth
BETTER_AUTH_SECRET=your_secret_at_least_32_chars

# Shopify
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_SECRET_TOKEN=shpat_xxx
SHOPIFY_ADMIN_SECRET_TOKEN=shpat_xxx
SHOPIFY_ADMIN_API_KEY=xxx
SHOPIFY_ADMIN_API_SECRET_KEY=shpss_xxx
SHOPIFY_API_VERSION=2025-10
SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_ID=xxx
SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_SECRET=xxx
SHOPIFY_CUSTOMER_ACCOUNT_SHOP_ID=xxx

# Database
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Payments
LIQPAY_PRIVATE_KEY=xxx
LIQPAY_PUBLIC_KEY=xxx

# Email
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=noreply@your-domain.com

# Marketing
ESPUTNIK_API_KEY=xxx
ESPUTNIK_API_LOGIN=xxx

# Sanity (server-only)
SANITY_API_READ_TOKEN=skXxx
# Renamed from NEXT_PUBLIC_SANITY_REVALIDATE_SECRET — webhook secret must NOT be client-exposed
SANITY_REVALIDATE_SECRET=xxx

# Google OAuth
GOOGLE_CLIENT_ID=xxx
GOOGLE_CLIENT_SECRET=xxx

# Storage / Integrations
BLOB_BASE_URL=https://...
PRICE_APP_URL=https://...

# Load testing (leave empty in production to disable the internal API route)
LOAD_TEST_SECRET=
